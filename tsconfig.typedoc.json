{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "es2015",
      "es2016",
      "es2017",
      "es2018",
      "es2019",
      "es2020",
      "dom",
      "dom.iterable"
    ],
    "types": ["node", "chrome", "lodash"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "output",
    "coverage",
    "others",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
