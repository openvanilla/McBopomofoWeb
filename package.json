{
  "name": "@openvanilla/mcbopomofoweb",
  "version": "2.0.4",
  "description": "McBopomofo input method built with TypeScript and other Web technologies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcbopomofo": "./output/cli/index.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src",
    "!src/chromeos_ime.ts",
    "!src/pime.ts",
    "!src/pime_keys.ts",
    "other",
    "README.md",
    "LICENSE.txt"
  ],
  "scripts": {
    "ts-build": "tsc",
    "ts-build:watch": "tsc -w",
    "build": "webpack --mode production",
    "build:chromeos": "webpack --mode production --config webpack.config.chromeext.js",
    "build:pime": "webpack --mode production --config webpack.config.pime.js",
    "build:mcp": "webpack --mode production --config webpack.config.mcp.js",
    "build:cli": "webpack --mode production --config webpack.config.cli.js",
    "build:dev": "webpack --mode development",
    "build:watch": "webpack --mode development --watch",
    "prepare": "tsc",
    "prepublishOnly": "npm run test && npm run eslint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "eslint": "eslint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openvanilla/McBopomofoWeb.git"
  },
  "author": "The McBopomofo Authors",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/openvanilla/McBopomofoWeb/issues"
  },
  "homepage": "https://github.com/openvanilla/McBopomofoWeb#readme",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "babel-loader": "^10.1.1",
    "chinese_convert": "^1.0.8",
    "dayjs": "^1.11.21",
    "lodash": "^4.18.1",
    "lunar-typescript": "^1.8.6",
    "lz-string": "^1.5.0",
    "minimatch": ">=10.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "core-js": "^3.49.0",
    "eslint": "^10.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "shx": "^0.4.0",
    "@babel/preset-typescript": "^7.28.5",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0"
  },
  "browser": {
    "assert": false
  }
}
